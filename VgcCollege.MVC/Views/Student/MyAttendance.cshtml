@model List<VgcCollege.Domain.Entities.CourseEnrolment>
@{
    ViewData["Title"] = "My Attendance";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Attendance</h2>
    <a asp-action="Dashboard" class="btn btn-outline-dark">Back</a>
</div>

@foreach (var e in Model)
{
    var present = e.AttendanceRecords.Count(a => a.Present);
    var total = e.AttendanceRecords.Count;
    var pct = total > 0 ? Math.Round((double)present / total * 100) : 0;

    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>@e.Course.Name</strong>
            <div>
                <span class="badge bg-secondary me-2">@present / @total sessions</span>
                <span class="badge @(pct >= 80 ? "bg-success" : pct >= 60 ? "bg-warning text-dark" : "bg-danger")">
                    @pct% attendance
                </span>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Week</th><th>Date</th><th>Status</th><th>Notes</th></tr>
                </thead>
                <tbody>
                    @foreach (var att in e.AttendanceRecords.OrderBy(a => a.WeekNumber))
                    {
                        <tr>
                            <td>Week @att.WeekNumber</td>
                            <td>@att.Date.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (att.Present)
                                {
                                    <span class="badge bg-success">Present</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger">Absent</span>
                                }
                            </td>
                            <td class="text-muted small">@att.Notes</td>
                        </tr>
                    }
                    @if (!e.AttendanceRecords.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-2">No records yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}