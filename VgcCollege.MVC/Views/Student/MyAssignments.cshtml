@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "My Assignments";
}

<div class="container mt-4">
    <h1 class="mb-4">My Assignment Results</h1>

    @if (Model.AssignmentResults != null && Model.AssignmentResults.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Assignment</th>
                    <th>Course</th>
                    <th>Mark</th>
                    <th>Feedback</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var result in Model.AssignmentResults)
                {
                    <tr>
                        <td>@result.Assignment?.Title</td>
                        <td>@result.Assignment?.Course?.Name</td>
                        <td>@result.Score</td>
                        <td>@result.Feedback</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No assignment results available.</p>
    }

    <a asp-action="Index" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Dashboard</a>
</div>