@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">
    <h1 class="mb-4">My Courses</h1>

    @if (Model.Enrolments != null && Model.Enrolments.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Branch</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enrolment in Model.Enrolments)
                {
                    <tr>
                        <td>@enrolment.Course?.Name</td>
                        <td>@enrolment.Course?.Branch?.Name</td>
                        <td>@enrolment.Course?.StartDate.ToShortDateString()</td>
                        <td>@enrolment.Course?.EndDate.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No enrolled courses found.</p>
    }

    <a asp-action="Index" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Dashboard</a>
</div>