@model IEnumerable<VgcCollege.Domain.Entities.Course>

@{
    ViewData["Title"] = "My Courses";
    var facultyId = ViewBag.FacultyId;
}

<h2>My Assigned Courses</h2>

<table class="table">
    <thead>
        <tr>
            <th>Course Name</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Name</td>
            </tr>
        }
    </tbody>
</table>

<p>
    <a asp-action="AddAssignment" asp-route-facultyId="@facultyId" class="btn btn-primary">Add Assignment</a>
    <a asp-action="AddExam" asp-route-facultyId="@facultyId" class="btn btn-success">Add Exam</a>
</p>