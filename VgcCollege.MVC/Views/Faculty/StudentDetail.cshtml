@model VgcCollege.Domain.Entities.StudentProfile
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <a asp-action="MyStudents" class="btn btn-outline-dark">Back</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header"><strong>Contact Details</strong></div>
            <div class="card-body">
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.Phone</p>
                <p><strong>Address:</strong> @Model.Address</p>
                <p class="mb-0"><strong>Student No:</strong> @Model.StudentNumber</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header"><strong>Enrolments</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Course</th><th>Branch</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Enrolments)
                        {
                            <tr>
                                <td>@e.Course.Name</td>
                                <td>@e.Course.Branch?.Name</td>
                                <td><span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">@e.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header"><strong>Assignment Results</strong></div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>Assignment</th><th>Score</th><th>Max</th><th>Feedback</th><th>Submitted</th></tr>
            </thead>
            <tbody>
                @foreach (var ar in Model.AssignmentResults)
                {
                    <tr>
                        <td>@ar.Assignment.Title</td>
                        <td>@ar.Score</td>
                        <td>@ar.Assignment.MaxScore</td>
                        <td>@ar.Feedback</td>
                        <td class="text-muted small">@ar.SubmittedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
                @if (!Model.AssignmentResults.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">No results yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header"><strong>Exam Results</strong></div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>Exam</th><th>Score</th><th>Max</th><th>Grade</th><th>Released</th></tr>
            </thead>
            <tbody>
                @foreach (var er in Model.ExamResults)
                {
                    <tr>
                        <td>@er.Exam.Title</td>
                        <td>@er.Score</td>
                        <td>@er.Exam.MaxScore</td>
                        <td><span class="badge bg-primary">@er.Grade</span></td>
                        <td>
                            <span class="badge @(er.Exam.ResultsReleased ? "bg-success" : "bg-warning text-dark")">
                                @(er.Exam.ResultsReleased ? "Released" : "Provisional")
                            </span>
                        </td>
                    </tr>
                }
                @if (!Model.ExamResults.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">No exam results yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>