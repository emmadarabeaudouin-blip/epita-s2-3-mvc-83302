@model List<VgcCollege.Domain.Entities.ExamResult>
@{ ViewData["Title"] = "Exam Results"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Exam Results</h2>
    <a asp-action="Dashboard" class="btn btn-outline-dark">Back</a>
</div>

<form method="get" class="mb-4">
    <select name="courseId" class="form-select" style="max-width:300px"
            onchange="this.form.submit()">
        <option value="">— Select a course —</option>
        @foreach (var c in ViewBag.Courses as List<VgcCollege.Domain.Entities.Course>)
        {
            if (c.Id == ViewBag.CourseId)
            {
                <option value="@c.Id" selected>@c.Name</option>
            }
            else
            {
                <option value="@c.Id">@c.Name</option>
            }
        }
    </select>
</form>

@if (ViewBag.CourseId != null && Model.Any())
{
    @* Group by exam to show release button per exam *@
    var exams = Model.GroupBy(r => r.Exam).ToList();
    foreach (var group in exams)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>@group.Key.Title</strong>
                    <span class="text-muted small ms-2">
                        @group.Key.Date.ToString("dd/MM/yyyy") — Max: @group.Key.MaxScore
                    </span>
                </div>
                @if (!group.Key.ResultsReleased)
                {
                    <form asp-action="ReleaseResults" method="post" asp-antiforgery="true"
                          onsubmit="return confirm('Release results for all students?')">
                        <input type="hidden" name="examId"   value="@group.Key.Id" />
                        <input type="hidden" name="courseId" value="@ViewBag.CourseId" />
                        <button class="btn btn-sm btn-warning">Release Results</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-success">Results Released</span>
                }
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Student</th><th>Score</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var r in group)
                    {
                        <tr>
                            <td>@r.StudentProfile.Name</td>
                            <td class="text-end">@r.Score</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else if (ViewBag.CourseId != null)
{
    <div class="alert alert-info" role="alert">
        No exam results found for the selected course.
    </div>
}