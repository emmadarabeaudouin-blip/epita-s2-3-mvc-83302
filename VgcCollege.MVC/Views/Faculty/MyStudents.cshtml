@model List<VgcCollege.Domain.Entities.CourseEnrolment>
@{
    ViewData["Title"] = "My Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Students</h2>
    <a asp-action="Dashboard" class="btn btn-outline-dark">Back</a>
</div>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.StudentProfile.Name</td>
                <td>@e.StudentProfile.Email</td>
                <td>@e.Course.Name</td>
                <td>@e.Course.Branch?.Name</td>
                <td>
                    <span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">
                        @e.Status
                    </span>
                </td>
                <td>
                    <a asp-action="StudentDetail" asp-route-id="@e.StudentProfile.Id"
                       class="btn btn-sm btn-outline-primary">View Profile</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="6" class="text-center text-muted py-3">No students assigned yet.</td></tr>
        }
    </tbody>
</table>