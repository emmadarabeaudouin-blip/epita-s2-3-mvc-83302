@model VgcCollege.Domain.Entities.FacultyProfile

@{
    ViewData["Title"] = "My Students";
}

<div class="container mt-4">
    <h1 class="mb-4">My Students</h1>

    @if (Model.CourseAssignments != null && Model.CourseAssignments.Any())
    {
        @foreach (var assignment in Model.CourseAssignments)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong>Course:</strong> @assignment.Course?.Name
                </div>
                <div class="card-body">
                    @if (assignment.Course?.Enrolments != null && assignment.Course.Enrolments.Any())
                    {
                        <table class="table table-bordered table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Student Name</th>
                                    <th>Enrol Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrolment in assignment.Course.Enrolments)
                                {
                                    <tr>
                                        <td>@enrolment.StudentProfile?.Name</td>
                                        <td>@enrolment.EnrolDate.ToShortDateString()</td>
                                        <td>@enrolment.Status</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="mb-0">No students enrolled in this course.</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p>No assigned courses found.</p>
    }

    <a asp-action="Index" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Dashboard</a>
</div>