@model VgcCollege.Domain.Entities.FacultyProfile

@{
    ViewData["Title"] = "Faculty Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">Faculty Dashboard</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4>Welcome, @Model.Name</h4>
            <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
            <p class="mb-0"><strong>Phone:</strong> @Model.Phone</p>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>My Profile</h5>
                    <a asp-controller="Faculty" asp-action="MyProfile" asp-route-id="@Model.Id" class="btn btn-primary">
                        View Profile
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>My Courses</h5>
                    <a asp-controller="Faculty" asp-action="MyCourses" asp-route-id="@Model.Id" class="btn btn-primary">
                        View Courses
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>My Students</h5>
                    <a asp-controller="Faculty" asp-action="MyStudents" asp-route-id="@Model.Id" class="btn btn-primary">
                        View Students
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>