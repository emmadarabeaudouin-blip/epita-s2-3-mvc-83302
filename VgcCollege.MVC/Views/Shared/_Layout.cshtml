@{
    var title = ViewData["Title"] as string ?? "VgcCollege";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - VgcCollege</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">VgcCollege</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @* Admin-only links *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Students">Students</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Faculty">Faculty</a>
                            </li>
                        }

                        @* Student-only links *@
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="Index" asp-route-id="1">Student</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="MyCourses" asp-route-id="1">My Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="MyResults" asp-route-id="1">My Results</a>
                            </li>
                        }
                        @if (User.IsInRole("Faculty"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Faculty" asp-action="Index" asp-route-id="1">Faculty</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Faculty" asp-action="MyCourses" asp-route-id="1">Faculty Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Faculty" asp-action="MyStudents" asp-route-id="1">Faculty Students</a>
                            </li>
                        }
                    </ul>

                    <span class="navbar-text text-light small me-3">
                        College Management System
                    </span>

                    @await Html.PartialAsync("_LoginPartial")
                </div>
            </div>
        </nav>
    </header>

    <main class="pb-4">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-3">
            &copy; @DateTime.Now.Year - VgcCollege
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>