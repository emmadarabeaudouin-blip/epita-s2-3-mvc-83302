@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">Admin Dashboard</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Students</h5>
                    <p class="card-text">Manage student profiles.</p>
                    <a asp-action="Students" class="btn btn-primary">View Students</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Faculty</h5>
                    <p class="card-text">Manage faculty profiles.</p>
                    <a asp-action="Faculty" class="btn btn-primary">View Faculty</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Assignments</h5>
                    <p class="card-text">Assign faculty to courses.</p>
                    <a asp-action="AssignFaculty" class="btn btn-primary">Assign Faculty</a>
                </div>
            </div>
        </div>
    </div>
</div>