@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mt-4">
    <div class="col-md-3 mb-3">
        <div class="card p-3">
            <h5>Branches</h5>
            <p>@ViewBag.BranchCount</p>
            <a asp-action="Branches" class="btn btn-primary btn-sm">Manage Branches</a>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card p-3">
            <h5>Courses</h5>
            <p>@ViewBag.CourseCount</p>
            <a asp-action="Courses" class="btn btn-primary btn-sm">Manage Courses</a>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card p-3">
            <h5>Students</h5>
            <p>@ViewBag.StudentCount</p>
            <a asp-action="Students" class="btn btn-primary btn-sm">Manage Students</a>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card p-3">
            <h5>Faculty</h5>
            <p>@ViewBag.FacultyCount</p>
            <a asp-action="Faculty" class="btn btn-primary btn-sm">Manage Faculty</a>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Enrolments" class="btn btn-outline-primary">Manage Enrolments</a>
    <a asp-action="FacultyAssignments" class="btn btn-outline-secondary">Manage Faculty Assignments</a>
</div>