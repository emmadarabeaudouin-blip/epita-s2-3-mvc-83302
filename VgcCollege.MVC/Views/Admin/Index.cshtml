@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm">
            <div class="card-body">
                <div class="fs-1 fw-bold text-primary">@ViewBag.BranchCount</div>
                <div class="text-muted">Branches</div>
                <a href="/Admin/Branches" class="btn btn-sm btn-outline-primary mt-2">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm">
            <div class="card-body">
                <div class="fs-1 fw-bold text-success">@ViewBag.CourseCount</div>
                <div class="text-muted">Courses</div>
                <a href="/Admin/Courses" class="btn btn-sm btn-outline-success mt-2">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm">
            <div class="card-body">
                <div class="fs-1 fw-bold text-warning">@ViewBag.StudentCount</div>
                <div class="text-muted">Students</div>
                <a href="/Admin/Students" class="btn btn-sm btn-outline-warning mt-2">View</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-0 shadow-sm">
            <div class="card-body">
                <div class="fs-1 fw-bold text-info">@ViewBag.FacultyCount</div>
                <div class="text-muted">Faculty</div>
                <a href="/Admin/Enrolments" class="btn btn-sm btn-outline-info mt-2">Enrolments</a>
            </div>
        </div>
    </div>
</div>
