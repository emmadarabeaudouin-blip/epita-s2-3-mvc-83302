@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">Admin Dashboard</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Students</h5>
                    <p class="card-text">Manage student profiles.</p>
                    <a asp-action="Students" class="btn btn-primary">View Students</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Faculty</h5>
                    <p class="card-text">Manage faculty profiles.</p>
                    <a asp-action="Faculty" class="btn btn-primary">View Faculty</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text">Manage courses. Total: @ViewBag.CourseCount</p>
                    <a asp-action="Courses" class="btn btn-primary">View Courses</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Assignments</h5>
                    <p class="card-text">Post assignment results for students.</p>
                    <a asp-action="AssignmentResults" class="btn btn-primary">View Assignment Results</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Exams</h5>
                    <p class="card-text">Post exam results for students.</p>
                    <a asp-action="ExamResults" class="btn btn-primary">View Exam Results</a>
                </div>
            </div>
        </div>
    </div>
</div>