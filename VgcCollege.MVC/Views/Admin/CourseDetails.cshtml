@model VgcCollege.Domain.Entities.Course
@{
    ViewData["Title"] = "Course — " + Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>@Model.Name</h2>
        <p class="text-muted mb-0">
            @Model.Branch.Name &bull;
            @Model.StartDate.ToString("dd/MM/yyyy") → @Model.EndDate.ToString("dd/MM/yyyy")
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditCourse" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Courses" class="btn btn-outline-dark">Back</a>
    </div>
</div>


<div class="card mb-4 shadow-sm">
    <div class="card-header"><strong>Faculty assigned</strong></div>
    <div class="card-body">
        @if (Model.FacultyAssignments.Any())
        {
            <ul class="mb-0">
                @foreach (var fa in Model.FacultyAssignments)
                {
                    <li>@fa.FacultyProfile.Name — @fa.FacultyProfile.Email</li>
                }
            </ul>
        }
        else
        {

            <span class="text-muted">No faculty assigned</span>
        }
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header d-flex justify-content-between">
        <strong>Enrolled students (@Model.Enrolments.Count)</strong>
        <a asp-action="CreateEnrolment" class="btn btn-sm btn-success">+ Enroll a student</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Attendance</th>
                    <th>Enrolled the</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Enrolments)
                {
                    var present = e.AttendanceRecords.Count(a => a.Present);
                    var total = e.AttendanceRecords.Count;
                    <tr>
                        <td>@e.StudentProfile.Name</td>
                        <td>@e.StudentProfile.Email</td>
                        <td>
                            <span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">
                                @e.Status
                            </span>
                        </td>
                        <td>
                            @if (total > 0)
                            {
                                <span>
                                    @present/@total
                                    (@Math.Round((double)present / total * 100)%)
                                </span>
                            }
                            else
                            {

                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@e.EnrolDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="StudentDetails" asp-route-id="@e.StudentProfile.Id"
                               class="btn btn-sm btn-outline-info">Profil</a>
                            <a asp-action="EnrolmentDetails" asp-route-id="@e.Id"
                               class="btn btn-sm btn-outline-secondary">Inscription</a>
                        </td>
                    </tr>
                }
                @if (!Model.Enrolments.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3"No student enrolled></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header"><strong>Assignments (@Model.Assignments.Count)</strong></div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>Titre</th><th>Note max</th><th>Deadline</th><th>Results</th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Assignments)
                {
                    <tr>
                        <td>@a.Title</td>
                        <td>@a.MaxScore</td>
                        <td>@a.DueDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge bg-secondary">@a.Results.Count submitted</span></td>
                    </tr>
                }
                @if (!Model.Assignments.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No assignment</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header"><strong>Examens (@Model.Exams.Count)</strong></div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>Titre</th><th>Date</th><th>Note max</th><th>Results published</th></tr>
            </thead>
            <tbody>
                @foreach (var ex in Model.Exams)
                {
                    <tr>
                        <td>@ex.Title</td>
                        <td>@ex.Date.ToString("dd/MM/yyyy")</td>
                        <td>@ex.MaxScore</td>
                        <td>
                            <span class="badge @(ex.ResultsReleased ? "bg-success" : "bg-warning text-dark")">
                                @(ex.ResultsReleased ? "Published" : "Provisional")
                            </span>
                        </td>
                    </tr>
                }
                @if (!Model.Exams.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No exams</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>