@model VgcCollege.Domain.Entities.Course
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Courses">Courses</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <h1>@Model.Name</h1>
        <p class="text-muted mb-0">
            @Model.Branch?.Name &bull;
            @Model.StartDate.ToString("dd MMM yyyy") → @Model.EndDate.ToString("dd MMM yyyy")
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditCourse" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Courses" class="btn btn-outline-dark">Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.Enrolments.Count</div>
            <div class="stat-label">Students Enrolled</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.Assignments.Count</div>
            <div class="stat-label">Assignments</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.Exams.Count</div>
            <div class="stat-label">Exams</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.FacultyAssignments.Count</div>
            <div class="stat-label">Faculty Assigned</div>
        </div>
    </div>
</div>

<!-- Faculty -->
@if (Model.FacultyAssignments.Any())
{
    <div class="detail-card mb-3">
        <div class="detail-header">Faculty</div>
        <div class="detail-body">
            @foreach (var fa in Model.FacultyAssignments)
            {
                <span class="badge bg-light text-dark border me-2 py-2 px-3">
                    @fa.FacultyProfile?.Name — @fa.FacultyProfile?.Email
                </span>
            }
        </div>
    </div>
}

<!-- Enrolled Students -->
<div class="table-card mb-3">
    <div class="card-header-bar">
        <h6>Enrolled Students (@Model.Enrolments.Count)</h6>
        <a asp-action="CreateEnrolment" class="btn btn-sm btn-primary">+ Enroll Student</a>
    </div>
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Email</th>
                <th>Status</th>
                <th>Attendance</th>
                <th>Enrolled</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Enrolments)
            {
                var present = e.AttendanceRecords?.Count(a => a.Present) ?? 0;
                var total = e.AttendanceRecords?.Count ?? 0;
                var pct = total > 0 ? (int)Math.Round((double)present / total * 100) : 0;
                <tr>
                    <td><strong>@e.StudentProfile?.Name</strong></td>
                    <td class="text-muted">@e.StudentProfile?.Email</td>
                    <td>
                        <span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">
                            @e.Status
                        </span>
                    </td>
                    <td>
                        <div class="att-bar">
                            <div class="att-bar-fill" style="width:@pct%"></div>
                        </div>
                        <span class="text-muted ms-1" style="font-size:.8rem">@pct%</span>
                    </td>
                    <td class="text-muted">@e.EnrolDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-action="StudentDetails" asp-route-id="@e.StudentProfile!.Id"
                           class="btn btn-sm btn-outline-primary me-1">Profile</a>
                        <a asp-action="EnrolmentDetails" asp-route-id="@e.Id"
                           class="btn btn-sm btn-outline-secondary">Enrolment</a>
                    </td>
                </tr>
            }
            @if (!Model.Enrolments.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No students enrolled yet.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Assignments -->
<div class="table-card mb-3">
    <div class="card-header-bar">
        <h6>Assignments (@Model.Assignments.Count)</h6>
        <div class="ms-auto">
            <a asp-action="CreateAssignment" asp-route-courseId="@Model.Id" class="btn btn-sm btn-primary">+ New Assignment</a>
        </div>
    </div>
    <table class="table mb-0">
        <thead>
            <tr><th>Title</th><th>Max Score</th><th>Due Date</th><th>Submissions</th></tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Assignments)
            {
                <tr>
                    <td>@a.Title</td>
                    <td>@a.MaxScore</td>
                    <td>@a.DueDate.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-secondary">@a.Results.Count submitted</span></td>
                </tr>
            }
            @if (!Model.Assignments.Any())
            {
                <tr><td colspan="4" class="text-center text-muted py-3">No assignments.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Exams -->
<div class="table-card">
    <div class="card-header-bar"><h6>Exams (@Model.Exams.Count)</h6></div>
    <div class="mb-2">
        <a asp-action="CreateExam" asp-route-courseId="@Model.Id" class="btn btn-sm btn-primary">+ New Exam</a>
    </div>
    <table class="table mb-0">
        <thead>
            <tr><th>Title</th><th>Date</th><th>Max Score</th><th>Results</th></tr>
        </thead>
        <tbody>
            @foreach (var ex in Model.Exams)
            {
                <tr>
                    <td>@ex.Title</td>
                    <td>@ex.Date.ToString("dd/MM/yyyy")</td>
                    <td>@ex.MaxScore</td>
                    <td>
                        <span class="badge @(ex.ResultsReleased ? "bg-success" : "bg-warning text-dark")">
                            @(ex.ResultsReleased ? "Released" : "Provisional")
                        </span>
                    </td>
                </tr>
            }
            @if (!Model.Exams.Any())
            {
                <tr><td colspan="4" class="text-center text-muted py-3">No exams.</td></tr>
            }
        </tbody>
    </table>
</div>