@model VgcCollege.Domain.Entities.CourseEnrolment

@{
    ViewData["Title"] = "Create Enrolment";
}

<h1>Create Enrolment</h1>

<form asp-action="CreateEnrolment" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="StudentProfileId" class="form-label">Student</label>
        <select asp-for="StudentProfileId" asp-items="ViewBag.Students" class="form-select">
            <option value="">-- Select Student --</option>
        </select>
        <span asp-validation-for="StudentProfileId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CourseId" class="form-label">Course</label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select">
            <option value="">-- Select Course --</option>
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EnrolDate" class="form-label"></label>
        <input asp-for="EnrolDate" class="form-control" type="date" />
        <span asp-validation-for="EnrolDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Enrolments" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}