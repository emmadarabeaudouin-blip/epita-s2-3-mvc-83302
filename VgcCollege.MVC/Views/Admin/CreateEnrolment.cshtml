@model VgcCollege.Domain.Entities.CourseEnrolment
@{
    ViewData["Title"] = "New Enrolment";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Enrolments">Enrolments</a></li>
                <li class="breadcrumb-item active">New Enrolment</li>
            </ol>
        </nav>
        <h1>Enrol a Student</h1>
    </div>
</div>

<div class="form-card">
    <form asp-action="CreateEnrolment" method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-4">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <div class="mb-4">
            <label class="form-label">Student</label>
            <select asp-for="StudentProfileId" class="form-select">
                <option value="">— Select Student —</option>
                @foreach (var s in ViewBag.Students as List<VgcCollege.Domain.Entities.StudentProfile>)
                {
                    <option value="@s.Id">@s.Name (@s.Email)</option>
                }
            </select>
        </div>
        <div class="mb-4">
            <label class="form-label">Course</label>
            <select asp-for="CourseId" class="form-select">
                <option value="">— Select Course —</option>
                @foreach (var c in ViewBag.Courses as List<VgcCollege.Domain.Entities.Course>)
                {
                    <option value="@c.Id">@c.Name (@c.Branch?.Name)</option>
                }
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Enrol Student</button>
            <a asp-action="Enrolments" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>