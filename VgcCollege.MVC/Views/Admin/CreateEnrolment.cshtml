@model VgcCollege.Domain.Entities.CourseEnrolment
@{
    ViewData["Title"] = "Enroll";
}

<h2 class="mb-4">Enroll a student</h2>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="CreateEnrolment" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Student</label>
                <select asp-for="StudentProfileId" class="form-select">
                    <option value="">— Choose a student —</option>
                    @foreach (var s in ViewBag.Students as List<VgcCollege.Domain.Entities.StudentProfile>)
                    {
                        <option value="@s.Id">@s.Name (@s.Email)</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Course</label>
                <select asp-for="CourseId" class="form-select">
                    <option value="">— Choose a course —</option>
                    @foreach (var c in ViewBag.Courses as List<VgcCollege.Domain.Entities.Course>)
                    {
                        <option value="@c.Id">@c.Name (@c.Branch.Name)</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Enroll</button>
                <a asp-action="Enrolments" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>