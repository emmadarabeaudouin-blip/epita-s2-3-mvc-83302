@model VgcCollege.Domain.Entities.Assignment
@{
    ViewData["Title"] = "Create Assignment";
}

<div class="page-header">
    <h1>Create Assignment</h1>
</div>

<div class="form-card">
    <form asp-action="CreateAssignment" asp-route-courseId="@Model.CourseId" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="CourseId" type="hidden" />

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="MaxScore" class="form-label">Max Score</label>
            <input asp-for="MaxScore" type="number" step="0.5" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="DueDate" class="form-label">Due Date</label>
            <input asp-for="DueDate" type="date" class="form-control" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="CourseDetails" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>