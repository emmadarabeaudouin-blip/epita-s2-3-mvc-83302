@model List<VgcCollege.Domain.Entities.CourseEnrolment>
@{
    ViewData["Title"] = "Enrolments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Enrolments</h2>
    <a asp-action="CreateEnrolment" class="btn btn-primary">+ Enroll</a>
</div>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Students</th>
            <th>Courses</th>
            <th>Branch</th>
            <th>Status</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.StudentProfile.Name</td>
                <td>@e.Course.Name</td>
                <td>@e.Course.Branch.Name</td>
                <td>
                    <span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">
                        @e.Status
                    </span>
                </td>
                <td>@e.EnrolDate.ToString("dd/MM/yyyy")</td>
                <td class="d-flex gap-1">
                    <a asp-action="EnrolmentDetails" asp-route-id="@e.Id"
                       class="btn btn-sm btn-outline-primary">Details</a>
                    <form asp-action="DeleteEnrolment" method="post"
                          onsubmit="return confirm('Delete this enrolment ?')">
                        <input type="hidden" name="id" value="@e.Id" />
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>