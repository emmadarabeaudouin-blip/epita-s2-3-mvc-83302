@using Microsoft.AspNetCore.Mvc.Rendering
@model VgcCollege.Domain.Entities.AssignmentResult

@{
    ViewData["Title"] = "Post Assignment Result";
}

<div class="container mt-4">
    <h1>Post Assignment Result</h1>

    <form asp-action="CreateAssignmentResult" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Assignment</label>
            <select asp-for="AssignmentId" class="form-select" asp-items="ViewBag.Assignments">
                <option value="">-- Select Assignment --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Student</label>
            <select asp-for="StudentProfileId" class="form-select" asp-items="ViewBag.Students">
                <option value="">-- Select Student --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Score</label>
            <input asp-for="Score" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Feedback</label>
            <textarea asp-for="Feedback" class="form-control"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Post</button>
        <a asp-action="AssignmentResults" class="btn btn-secondary">Cancel</a>
    </form>
</div>