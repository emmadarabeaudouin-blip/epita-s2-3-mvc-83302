@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <h1 class="mb-3">Student Details</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Student Number:</strong> @Model.StudentNumber</p>
        </div>
    </div>

    <h3>Enrolments</h3>
    @if (Model.Enrolments.Any())
    {
        <ul class="list-group mb-4">
            @foreach (var enrolment in Model.Enrolments)
            {
                <li class="list-group-item">
                    @enrolment.Course?.Name
                    @if (enrolment.Course?.Branch != null)
                    {
                        <span>- @enrolment.Course.Branch.Name</span>
                    }
                </li>
            }
        </ul>
    }
    else
    {
        <p>No enrolments.</p>
    }

    <a asp-action="Students" class="btn btn-secondary">Back</a>
</div>