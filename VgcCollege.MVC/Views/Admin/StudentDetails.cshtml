@model VgcCollege.Domain.Entities.StudentProfile

@{
    ViewData["Title"] = "Student Details";
}

<h1>Student Details</h1>

<div class="card p-3 mb-4">
    <h4>@Model.Name</h4>
    <p><strong>Student Number:</strong> @Model.StudentNumber</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Phone:</strong> @Model.Phone</p>
    <p><strong>Address:</strong> @Model.Address</p>
    <p><strong>DOB:</strong> @Model.DateOfBirth.ToShortDateString()</p>
</div>

<h4>Enrolments</h4>
@if (Model.Enrolments.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Course</th>
                <th>Branch</th>
                <th>Enrol Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var enrolment in Model.Enrolments)
            {
                <tr>
                    <td>@enrolment.Course?.Name</td>
                    <td>@enrolment.Course?.Branch?.Name</td>
                    <td>@enrolment.EnrolDate.ToShortDateString()</td>
                    <td>@enrolment.Status</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No enrolments found.</p>
}

<a asp-action="Students" class="btn btn-secondary">Back</a>