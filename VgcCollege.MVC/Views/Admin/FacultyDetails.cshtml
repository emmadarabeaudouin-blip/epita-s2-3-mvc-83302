@model VgcCollege.Domain.Entities.FacultyProfile

@{
    ViewData["Title"] = "Faculty Details";
}

<div class="container mt-4">
    <h1 class="mb-3">Faculty Details</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Email:</strong> @Model.Email</p>
        </div>
    </div>

    <h3>Assigned Courses</h3>
    @if (Model.CourseAssignments.Any())
    {
        <ul class="list-group mb-4">
            @foreach (var assignment in Model.CourseAssignments)
            {
                <li class="list-group-item">
                    @assignment.Course?.Name
                    @if (assignment.Course?.Branch != null)
                    {
                        <span>- @assignment.Course.Branch.Name</span>
                    }
                </li>
            }
        </ul>
    }
    else
    {
        <p>No assigned courses.</p>
    }

    <a asp-action="Faculty" class="btn btn-secondary">Back</a>
</div>