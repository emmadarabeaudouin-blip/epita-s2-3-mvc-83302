@model VgcCollege.Domain.Entities.Course
@{
    ViewData["Title"] = "New Course";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Courses">Courses</a></li>
                <li class="breadcrumb-item active">New Course</li>
            </ol>
        </nav>
        <h1>New Course</h1>
    </div>
</div>

<div class="form-card">
    <form asp-action="CreateCourse" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
            <label asp-for="Name" class="form-label">Course Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. BSc Computer Science" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="BranchId" class="form-label">Branch</label>
            <select asp-for="BranchId" class="form-select" asp-items="ViewBag.Branches">
                <option value="">— Select Branch —</option>
            </select>
            <span asp-validation-for="BranchId" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create Course</button>
            <a asp-action="Courses" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>