@model VgcCollege.Domain.Entities.CourseEnrolment
@{
    ViewData["Title"] = "Enrolments — " + Model.StudentProfile.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Enrolments</h2>
    <a asp-action="Enrolments" class="btn btn-outline-dark">Back</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header"><strong>Students</strong></div>
            <div class="card-body">
                <p><strong>Name :</strong> @Model.StudentProfile.Name</p>
                <p><strong>Email :</strong> @Model.StudentProfile.Email</p>
                <a asp-action="StudentDetails" asp-route-id="@Model.StudentProfile.Id"
                   class="btn btn-sm btn-outline-info">See complete profile</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header"><strong>Cours</strong></div>
            <div class="card-body">
                <p><strong>Courses :</strong> @Model.Course.Name</p>
                <p><strong>Branch :</strong> @Model.Course.Branch.Name</p>
                <p>
                    <strong>Status :</strong>
                    <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">
                        @Model.Status
                    </span>
                </p>
                <a asp-action="CourseDetails" asp-route-id="@Model.Course.Id"
                   class="btn btn-sm btn-outline-primary">See course</a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>
            Attendance —
            @Model.AttendanceRecords.Count(a => a.Present) /
            @Model.AttendanceRecords.Count weeks
        </strong>
    </div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>Week</th><th>Date</th><th>Present</th><th>Notes</th></tr>
            </thead>
            <tbody>
                @foreach (var att in Model.AttendanceRecords.OrderBy(a => a.WeekNumber))
                {
                    <tr>
                        <td>Week @att.WeekNumber</td>
                        <td>@att.Date.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (att.Present)
                            {
                                <span class="badge bg-success">Present</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">Absent</span>
                            }
                        </td>
                        <td>@att.Notes</td>
                    </tr>
                }
                @if (!Model.AttendanceRecords.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No attendance registered</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
