@model VgcCollege.Domain.Entities.CourseEnrolment
@{
    ViewData["Title"] = "Enrolment Details";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Enrolments">Enrolments</a></li>
                <li class="breadcrumb-item active">@Model.StudentProfile?.Name</li>
            </ol>
        </nav>
        <h1>Enrolment Details</h1>
    </div>
    <a asp-action="Enrolments" class="btn btn-outline-dark">Back</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="detail-card">
            <div class="detail-header">Student</div>
            <div class="detail-body">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted" style="width:120px">Name</td><td><strong>@Model.StudentProfile?.Name</strong></td></tr>
                    <tr><td class="text-muted">Email</td><td>@Model.StudentProfile?.Email</td></tr>
                    <tr><td class="text-muted">Phone</td><td>@Model.StudentProfile?.Phone</td></tr>
                </table>
                <a asp-action="StudentDetails" asp-route-id="@Model.StudentProfile!.Id"
                   class="btn btn-sm btn-outline-primary mt-2">Full Profile</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="detail-card">
            <div class="detail-header">Course</div>
            <div class="detail-body">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted" style="width:120px">Course</td><td><strong>@Model.Course?.Name</strong></td></tr>
                    <tr><td class="text-muted">Branch</td><td>@Model.Course?.Branch?.Name</td></tr>
                    <tr>
                        <td class="text-muted">Status</td>
                        <td>
                            <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                    <tr><td class="text-muted">Enrolled</td><td>@Model.EnrolDate.ToString("dd/MM/yyyy")</td></tr>
                </table>
                <a asp-action="CourseDetails" asp-route-id="@Model.Course!.Id"
                   class="btn btn-sm btn-outline-primary mt-2">View Course</a>
            </div>
        </div>
    </div>
</div>

<!-- Attendance -->
@{
    var present = Model.AttendanceRecords?.Count(a => a.Present) ?? 0;
    var total = Model.AttendanceRecords?.Count ?? 0;
    var pct = total > 0 ? (int)Math.Round((double)present / total * 100) : 0;
}

<div class="table-card">
    <div class="card-header-bar">
        <h6>Attendance — @present / @total sessions (@pct%)</h6>
    </div>
    <table class="table table-hover mb-0">
        <thead>
            <tr><th>Week</th><th>Date</th><th>Status</th><th>Notes</th></tr>
        </thead>
        <tbody>
            @if (Model.AttendanceRecords != null && Model.AttendanceRecords.Any())
            {
                foreach (var att in Model.AttendanceRecords.OrderBy(a => a.WeekNumber))
                {
                    <tr>
                        <td>Week @att.WeekNumber</td>
                        <td>@att.Date.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @(att.Present ? "bg-success" : "bg-danger")">
                                @(att.Present ? "Present" : "Absent")
                            </span>
                        </td>
                        <td class="text-muted">@att.Notes</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center text-muted py-4">No attendance records yet.</td></tr>
            }
        </tbody>
    </table>
</div>