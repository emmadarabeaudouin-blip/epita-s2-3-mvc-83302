@model VgcCollege.Domain.Entities.Branch
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Branches">Branches</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
        <h1>@Model.Name</h1>
        <p class="text-muted mb-0">@Model.Address</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditBranch" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Branches" class="btn btn-outline-dark">Back</a>
    </div>
</div>

<h6 class="text-muted text-uppercase fw-semibold mb-3" style="font-size:.75rem;letter-spacing:.05em">
    Courses in this branch — @Model.Courses.Count
</h6>

@foreach (var course in Model.Courses)
{
    <div class="detail-card mb-3">
        <div class="detail-header d-flex justify-content-between align-items-center">
            <div>
                @course.Name
                <span class="text-muted fw-normal ms-2" style="font-size:.8rem">
                    @course.StartDate.ToString("dd/MM/yyyy") → @course.EndDate.ToString("dd/MM/yyyy")
                </span>
            </div>
            <a asp-action="CourseDetails" asp-route-id="@course.Id"
               class="btn btn-sm btn-primary">View Course</a>
        </div>
        <div class="detail-body p-0">
            @if (course.FacultyAssignments != null && course.FacultyAssignments.Any())
            {
                <div class="px-4 py-2 border-bottom" style="font-size:.85rem;background:#fafafa">
                    <strong>Faculty:</strong>
                    @string.Join(", ", course.FacultyAssignments.Select(fa => fa.FacultyProfile?.Name ?? "—"))
                </div>
            }
            <table class="table table-hover mb-0" style="font-size:.875rem">
                <thead style="background:#f8fafc">
                    <tr>
                        <th style="padding:.6rem 1.25rem;font-size:.72rem;text-transform:uppercase;color:#64748b">Student</th>
                        <th style="padding:.6rem 1.25rem;font-size:.72rem;text-transform:uppercase;color:#64748b">Email</th>
                        <th style="padding:.6rem 1.25rem;font-size:.72rem;text-transform:uppercase;color:#64748b">Status</th>
                        <th style="padding:.6rem 1.25rem;font-size:.72rem;text-transform:uppercase;color:#64748b">Enrolled</th>
                        <th style="padding:.6rem 1.25rem"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (course.Enrolments != null && course.Enrolments.Any())
                    {
                        foreach (var e in course.Enrolments)
                        {
                            <tr>
                                <td style="padding:.65rem 1.25rem">@e.StudentProfile?.Name</td>
                                <td style="padding:.65rem 1.25rem" class="text-muted">@e.StudentProfile?.Email</td>
                                <td style="padding:.65rem 1.25rem">
                                    <span class="badge @(e.Status == "Active" ? "bg-success" : "bg-secondary")">
                                        @e.Status
                                    </span>
                                </td>
                                <td style="padding:.65rem 1.25rem" class="text-muted">
                                    @e.EnrolDate.ToString("dd/MM/yyyy")
                                </td>
                                <td style="padding:.65rem 1.25rem">
                                    <a asp-action="StudentDetails" asp-route-id="@e.StudentProfile!.Id"
                                       class="btn btn-sm btn-outline-primary">Profile</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No students enrolled</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!Model.Courses.Any())
{
    <div class="detail-card">
        <div class="detail-body text-center text-muted py-4">
            No courses in this branch yet.
            <br />
            <a asp-action="CreateCourse" class="btn btn-primary mt-3">Add a Course</a>
        </div>
    </div>
}