@model VgcCollege.Domain.Entities.Course
@{ ViewData["Title"] = "Edit Course"; }

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Courses">Courses</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
        <h1>Edit Course</h1>
    </div>
</div>

<div class="form-card">
    <form asp-action="EditCourse" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-4">
            <label asp-for="Name" class="form-label">Course Name</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="BranchId" class="form-label">Branch</label>
            <select asp-for="BranchId" class="form-select" asp-items="ViewBag.Branches"></select>
        </div>
        <div class="mb-4">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="CourseDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>