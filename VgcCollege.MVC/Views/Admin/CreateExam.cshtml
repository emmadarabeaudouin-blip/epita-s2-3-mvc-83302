@model VgcCollege.Domain.Entities.Exam
@{
    ViewData["Title"] = "Create Exam";
}

<div class="page-header">
    <h1>Create Exam</h1>
</div>

<div class="form-card">
    <form asp-action="CreateExam" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="CourseId" type="hidden" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="MaxScore" class="form-label">Max Score</label>
            <input asp-for="MaxScore" type="number" step="0.5" class="form-control" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="CourseDetails" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>