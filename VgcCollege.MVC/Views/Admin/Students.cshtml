@model IEnumerable<VgcCollege.Domain.Entities.StudentProfile>

@{
    ViewData["Title"] = "Students";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Students</h1>
        <a asp-action="CreateStudent" class="btn btn-success">+ Add Student</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Student Number</th>
                <th>Enrolments</th>
                <th style="width: 260px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Name</td>
                    <td>@student.Email</td>
                    <td>@student.StudentNumber</td>
                    <td>@student.Enrolments.Count</td>
                    <td>
                        <a asp-action="StudentDetails" asp-route-id="@student.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="EditStudent" asp-route-id="@student.Id" class="btn btn-sm btn-warning">Edit</a>

                        <form asp-action="DeleteStudent" asp-route-id="@student.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Delete this student?');">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>