@* EditBranch.cshtml *@
@model VgcCollege.Domain.Entities.Branch
@{
    ViewData["Title"] = "Edit Branch";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Branches">Branches</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
        <h1>Edit Branch</h1>
    </div>
</div>

<div class="form-card">
    <form asp-action="EditBranch" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-4">
            <label asp-for="Name" class="form-label">Branch Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Address" class="form-label">Address</label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="BranchDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>