@model VgcCollege.MVC.Models.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — VGC College</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        body { background: #0f1f3d; min-height: 100vh;
               display: flex; align-items: center; justify-content: center; }
        .login-card { background: #fff; border-radius: 12px; padding: 2.5rem;
                      width: 100%; max-width: 400px; }
        .login-card h4 { font-weight: 700; color: #0f1f3d; }
        .form-control { border-radius: 6px; font-size: .875rem; }
        .form-label { font-size: .8rem; font-weight: 600; color: #374151; }
        .btn-login { background: #1a56db; border: none; border-radius: 6px;
                     padding: .65rem; font-weight: 600; }
        .demo-box { background: #f8fafc; border-radius: 8px; padding: .875rem;
                    font-size: .78rem; color: #64748b; }
        .demo-box strong { color: #374151; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="text-center mb-4">
        <h4>VGC College</h4>
        <p class="text-muted small">Student & Course Management</p>
    </div>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div asp-validation-summary="All" class="alert alert-danger small py-2 mb-3"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="you@vgc.ie" />
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" />
        </div>
        <div class="mb-4 form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label" style="font-size:.85rem">Remember me</label>
        </div>
        <button type="submit" class="btn btn-login btn-primary w-100 text-white">Sign in</button>
    </form>

    <div class="demo-box mt-4">
        <div class="mb-1"><strong>Admin:</strong> admin@vgc.ie / Admin123</div>
        <div class="mb-1"><strong>Faculty:</strong> faculty@vgc.ie / Faculty123</div>
        <div class="mb-1"><strong>Student:</strong> student1@vgc.ie / Student123</div>
    </div>
</div>
</body>
</html>